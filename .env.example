# ===========================================
# PEP Collector — Environment Configuration
# ===========================================

# Neo4j Database
# For local dev with docker-compose, use: neo4j://neo4j:7687
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# Auth0 — Create an API in your Auth0 tenant
# See README for setup instructions
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_AUDIENCE=https://pep-collector/api

# Server
PORT=3000

# CORS — comma-separated allowed origins (omit to allow all)
# ALLOWED_ORIGINS=https://your-app.com,http://localhost:3000

# Matching tuning (optional)
# RETRIEVE_LIMIT=20
# MAX_RESULTS=10

# Scheduled Crawls (optional)
# Cron expression for automatic data crawls
# Omit to disable — crawls will be on-demand only via trigger_crawl tool
# Examples: "0 2 * * *" (daily 2am), "0 */6 * * *" (every 6 hours)
# CRAWL_SCHEDULE=0 2 * * *
