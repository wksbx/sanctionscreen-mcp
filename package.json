{
  "name": "pep-collector",
  "version": "1.0.0",
  "description": "MCP server for PEP and sanctions screening with fuzzy matching search",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pep-collector/pep-collector.git"
  },
  "keywords": [
    "mcp",
    "pep",
    "sanctions",
    "screening",
    "aml",
    "compliance",
    "fuzzy-matching"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch main.ts",
    "dev:stdio": "tsx main.ts --stdio",
    "build:ui": "tsx build-ui.ts",
    "build:server": "tsup main.ts --format esm --out-dir dist --tsconfig tsconfig.server.json",
    "build": "pnpm run build:ui && pnpm run build:server",
    "start": "node dist/main.js",
    "start:stdio": "node dist/main.js --stdio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "neo4j-driver": "^6.0.1",
    "node-cron": "^3.0.3",
    "transliteration": "^2.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "cross-env": "^7.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.2"
  }
}
